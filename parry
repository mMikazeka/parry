local function updateToggleVisual()
    if parryEnabled then
        ToggleBtn.Text = "ENABLED"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 220, 130)
        ToggleBtn.TextColor3 = Color3.fromRGB(18, 18, 22)
        StatusLabel.Text = "PARRY ACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(100, 220, 130)
    else
        ToggleBtn.Text = "DISABLED"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(70, 70, 82)
        ToggleBtn.TextColor3 = Color3.fromRGB(160, 160, 170)
        StatusLabel.Text = "PARRY INACTIVE"
        StatusLabel.TextColor3 = Color3.fromRGB(160, 80, 80)
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    parryEnabled = not parryEnabled
    updateToggleVisual()
end)
local function setKey(keyCode)
    currentKey = keyCode
    local name = keyCode.Name
    KeyBindBtn.Text = "[ " .. name .. " ]"
    KeyHint.Text = "bind: [ " .. name .. " ]"
    KeyBindStroke.Color = Color3.fromRGB(60, 60, 75)
    KeyBindBtn.TextColor3 = Color3.fromRGB(255, 220, 60)
end

KeyBindBtn.MouseButton1Click:Connect(function()
    if isListeningForKey then return end
    isListeningForKey = true
    KeyBindBtn.Text = "press a key..."
    KeyBindBtn.TextColor3 = Color3.fromRGB(255, 180, 40)
    KeyBindStroke.Color = Color3.fromRGB(255, 220, 60)

    local conn
    conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if input.UserInputType == Enum.UserInputType.Keyboard then
            conn:Disconnect()
            isListeningForKey = false
            setKey(input.KeyCode)
        end
    end)
end)
local function switchTab(tab)
    if tab == "main" then
        MainPage.Visible = true
        SettingsPage.Visible = false
        TabMain.TextColor3 = Color3.fromRGB(255, 220, 60)
        TabSettings.TextColor3 = Color3.fromRGB(160, 160, 170)
        TweenService:Create(TabIndicator, TweenInfo.new(0.15), {
            Position = UDim2.new(0, 0, 1, -2)
        }):Play()
    else
        MainPage.Visible = false
        SettingsPage.Visible = true
        TabMain.TextColor3 = Color3.fromRGB(160, 160, 170)
        TabSettings.TextColor3 = Color3.fromRGB(255, 220, 60)
        TweenService:Create(TabIndicator, TweenInfo.new(0.15), {
            Position = UDim2.new(0.5, 0, 1, -2)
        }):Play()
    end
end

TabMain.MouseButton1Click:Connect(function() switchTab("main") end)
TabSettings.MouseButton1Click:Connect(function() switchTab("settings") end)
